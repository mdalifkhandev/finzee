# FinZee AI - Expo Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the real .env file - it is already in .gitignore.

# —— Supabase ———————————————————
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api-keys
# Use the PUBLISHABLE key (safe for client-side). NEVER use the secret key here.
EXPO_PUBLIC_SUPABASE_URL=https://ddfphvqmgmhfajqbgbpk.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRkZnBodnFtZ21oZmFqcWJnYnBrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE3NDk4MzcsImV4cCI6MjA5NzMyNTgzN30.3O7xlIfQn7a3H-KsBSbjwnHlFVxG9GsXM6VaF4cxia0

# —— API Base URL —————————————————
# For services that use a separate REST API backend
API_BASE_URL=https://ddfphvqmgmhfajqbgbpk.supabase.co
EXPO_PUBLIC_API_BASE_URL=https://ddfphvqmgmhfajqbgbpk.supabase.co

# —— Web App URL —————————————————
# Used for password reset links when the app runs on web
EXPO_PUBLIC_WEB_APP_URL=https://finzee-ai.vercel.app

# —— Legacy keys (for backwards compatibility) ——
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRkZnBodnFtZ21oZmFqcWJnYnBrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE3NDk4MzcsImV4cCI6MjA5NzMyNTgzN30.3O7xlIfQn7a3H-KsBSbjwnHlFVxG9GsXM6VaF4cxia0

# —— Optional: Feature Flags —————
# EXPO_PUBLIC_DEV_MODE=false
EXPO_PUBLIC_DEV_MODE=false

# ———————————————————————————————————————————————
# SERVER-SIDE SECRETS (Supabase Edge Function secrets — NOT client env)
# Set these with: supabase secrets set KEY=value
# The app never sees these; they are read by Deno.env inside edge functions.
# Endpoints degrade to realistic mock/stub data when a provider key is absent,
# so the app works end-to-end even before these are configured.
# ———————————————————————————————————————————————
