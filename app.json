{
  "expo": {
    "name": "FinZee AI",
    "slug": "my-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "finzeeai",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "backgroundColor": "#06080f",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.finzeeai.myapp",
      "buildNumber": "1",
      "runtimeVersion": {
        "policy": "appVersion"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.finzeeai.myapp",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1,
      "minSdkVersion": 26,
      "permissions": [
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_MINDFULNESS",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_MINDFULNESS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#06080f"
      },
      "runtimeVersion": "1.0.0"
    },
    "androidStatusBar": {
      "backgroundColor": "#06080f",
      "barStyle": "light-content",
      "translucent": false
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-dev-client",
      "react-native-health-connect",
      [
        "react-native-health",
        {
          "healthSharePermission": "FinZee AI reads steps, sleep, heart rate, and mindfulness data to personalize financial wellness insights.",
          "healthUpdatePermission": "FinZee AI does not write health data."
        }
      ],
      "./plugins/withFmtXcode26Fix"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "cc6b788c-3ba1-41c0-8cea-5ba6fcc4913d"
      }
    },
    "owner": "jaymelvin",
    "updates": {
      "url": "https://u.expo.dev/cc6b788c-3ba1-41c0-8cea-5ba6fcc4913d"
    }
  }
}
