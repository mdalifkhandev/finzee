{
  "expo": {
    "name": "FinZee AI",
    "slug": "my-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "finzeeai",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "backgroundColor": "#06080f",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.finzeeai.myapp",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.finzeeai.myapp",
      "versionCode": 1,
      "minSdkVersion": 26,
      "adaptiveIcon": {
        "backgroundColor": "#06080f"
      }
    },
    "androidStatusBar": {
      "backgroundColor": "#06080f",
      "barStyle": "light-content",
      "translucent": false
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-dev-client",
      "./plugins/withFmtXcode26Fix"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "cc6b788c-3ba1-41c0-8cea-5ba6fcc4913d"
      }
    }
  }
}
